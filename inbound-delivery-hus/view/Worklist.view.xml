<mvc:View
    controllerName="kejriwal.mm.inboundhus.controller.Worklist"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    displayBlock="true">
    <Page id="page" title="{i18n>appTitle}">
        <content>
            <Table
                id="table"
                items="{/InboundHu}"
                mode="MultiSelect"
                growing="true"
                growingThreshold="50">
                <headerToolbar>
                    <OverflowToolbar>
                        <Title text="{i18n>worklistTitle}"/>
                        <ToolbarSpacer/>
                        <Button text="{i18n>actpostInboundGr}" press=".onPostInboundGr" type="Emphasized"/>
                    </OverflowToolbar>
                </headerToolbar>
                <columns>
                        <Column><Text text="{i18n>colHandlingUnit}"/></Column>
                        <Column><Text text="{i18n>colInboundDelivery}"/></Column>
                        <Column><Text text="{i18n>colPackagingMaterial}"/></Column>
                </columns>
                <items>
                    <ColumnListItem>
                        <cells>
                            <Text text="{HandlingUnit}"/>
                            <Text text="{InboundDelivery}"/>
                            <Text text="{PackagingMaterial}"/>
                        </cells>
                    </ColumnListItem>
                </items>
            </Table>
        </content>
    </Page>
</mvc:View>
