// Read existing HUs for a reference + a static action that creates the textile
// cone/carton/pallet HU hierarchy via the standard HU API. Unmanaged.
unmanaged implementation in class zbp_i_packing_unit unique;
strict ( 2 );

define behavior for ZI_Packing_Unit alias PackingUnit
{
  static action createHandlingUnits
    parameter ZD_Pack_Create
    result [1] ZD_Pack_Result;
}
