<mvc:View
    controllerName="kejriwal.sd.dispatchcorrection.controller.Worklist"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    displayBlock="true">
    <Page id="page" title="{i18n>appTitle}">
        <content>
            <Table
                id="table"
                items="{/DispatchBox}"
                mode="MultiSelect"
                growing="true"
                growingThreshold="50">
                <headerToolbar>
                    <OverflowToolbar>
                        <Title text="{i18n>worklistTitle}"/>
                        <ToolbarSpacer/>
                        <Button text="{i18n>actcorrectDispatch}" press=".onCorrectDispatch" type="Emphasized"/>
                    </OverflowToolbar>
                </headerToolbar>
                <columns>
                        <Column><Text text="{i18n>colBoxNumber}"/></Column>
                        <Column><Text text="{i18n>colSalesOrder}"/></Column>
                        <Column><Text text="{i18n>colSalesOrderItem}"/></Column>
                        <Column><Text text="{i18n>colMaterial}"/></Column>
                        <Column><Text text="{i18n>colGrade}"/></Column>
                        <Column><Text text="{i18n>colStatus}"/></Column>
                </columns>
                <items>
                    <ColumnListItem>
                        <cells>
                            <Text text="{BoxNumber}"/>
                            <Text text="{SalesOrder}"/>
                            <Text text="{SalesOrderItem}"/>
                            <Text text="{Material}"/>
                            <Text text="{Grade}"/>
                            <Text text="{Status}"/>
                        </cells>
                    </ColumnListItem>
                </items>
            </Table>
        </content>
    </Page>
</mvc:View>
