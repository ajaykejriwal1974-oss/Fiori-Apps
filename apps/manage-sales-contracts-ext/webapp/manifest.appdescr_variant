{
  "fileName": "manifest",
  "layer": "CUSTOMER_BASE",
  "fioriId": "REPLACE_WITH_BASE_APP_FIORI_ID",
  "id": "kejriwal.zcontract.manage.extension",
  "reference": "REPLACE_WITH_BASE_APP_COMPONENT_ID",
  "namespace": "apps/REPLACE_WITH_BASE_APP_COMPONENT_ID/changes/kejriwal/zcontract/manage/extension/",
  "version": "1.0.0",
  "packageName": "$TMP",
  "content": [
    {
      "changeType": "appdescr_app_setTitle",
      "content": {},
      "texts": {
        "i18n": "i18n/i18n.properties"
      }
    },
    {
      "changeType": "appdescr_app_addNewInbound",
      "content": {
        "inbound": {
          "SalesContract-manageKejriwal": {
            "semanticObject": "SalesContract",
            "action": "manageKejriwal",
            "icon": "sap-icon://document",
            "title": "{{flpTitle}}",
            "subTitle": "{{flpSubtitle}}",
            "signature": {
              "parameters": {},
              "additionalParameters": "allowed"
            }
          }
        }
      },
      "texts": {
        "i18n": "i18n/i18n.properties"
      }
    },
    {
      "changeType": "appdescr_ui_generic_app_changePageConfiguration",
      "content": {
        "parentPage": {
          "component": "sap.suite.ui.generic.template.ObjectPage",
          "entitySet": "C_SalesContract"
        },
        "entityPropertyChange": {
          "propertyPath": "component/settings/sections/ContractStatusSection",
          "operation": "UPSERT",
          "propertyValue": {
            "id": "ContractStatusSection",
            "title": "{i18n>contractStatusRate}",
            "template": "kejriwal.zcontract.manage.extension.changes.fragments.ContractStatusActions"
          }
        }
      }
    }
  ]
}
