<mvc:View
    controllerName="kejriwal.pp.batchstatus.controller.Worklist"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    displayBlock="true">
    <Page id="page" title="{i18n>appTitle}">
        <content>
            <Table
                id="table"
                items="{/Batch}"
                mode="MultiSelect"
                growing="true"
                growingThreshold="50">
                <headerToolbar>
                    <OverflowToolbar>
                        <Title text="{i18n>worklistTitle}"/>
                        <ToolbarSpacer/>
                        <Button text="{i18n>actcloseBatch}" press=".onCloseBatch" type="Emphasized"/>
                        <Button text="{i18n>actdeleteBatch}" press=".onDeleteBatch" type="Emphasized"/>
                    </OverflowToolbar>
                </headerToolbar>
                <columns>
                        <Column><Text text="{i18n>colMaterial}"/></Column>
                        <Column><Text text="{i18n>colPlant}"/></Column>
                        <Column><Text text="{i18n>colBatch}"/></Column>
                        <Column><Text text="{i18n>colLastGoodsReceiptDate}"/></Column>
                </columns>
                <items>
                    <ColumnListItem>
                        <cells>
                            <Text text="{Material}"/>
                            <Text text="{Plant}"/>
                            <Text text="{Batch}"/>
                            <Text text="{LastGoodsReceiptDate}"/>
                        </cells>
                    </ColumnListItem>
                </items>
            </Table>
        </content>
    </Page>
</mvc:View>
