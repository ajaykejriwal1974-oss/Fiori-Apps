<!--
  Custom UI section for Manage Outbound Deliveries (F0867A).
  Re-adds the delivery-challan fields that used to live behind ZDEL
  (program ZRPT_DELIVERY_CHALLAN), and a button to print the challan.

  CLEAN-CORE NOTE:
  - The fields below can only bind to data the OData service exposes. The
    YY1_* delivery extension fields must be added on the backend first via
    in-app key-user field extensibility / custom CDS on the outbound delivery,
    then exposed on the C_OutboundDelivery entity.
  - The challan PRINT itself is NOT done here. It is an Output Management
    (BRF+) determination rendering an Adobe form (the clean-core replacement
    for ZRPT_DELIVERY_CHALLAN). The button only triggers that output.
-->
<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:form="sap.ui.layout.form">
    <Panel id="deliveryChallanPanel" headerText="{i18n>deliveryChallan}" expandable="true" expanded="true">
        <form:SimpleForm
            id="deliveryChallanForm"
            layout="ResponsiveGridLayout"
            editable="true"
            labelSpanXL="3" labelSpanL="3" labelSpanM="4" labelSpanS="12"
            columnsXL="2" columnsL="2" columnsM="1">
            <form:content>
                <Label text="{i18n>challanNo}" />
                <Input id="inpChallanNo" value="{YY1_ChallanNo_DEL}" />

                <Label text="{i18n>challanDate}" />
                <DatePicker id="inpChallanDate" value="{YY1_ChallanDate_DEL}" />

                <Label text="{i18n>vehicleNo}" />
                <Input id="inpVehicleNo" value="{YY1_VehicleNo_DEL}" />

                <Label text="{i18n>transporter}" />
                <Input id="inpTransporter" value="{YY1_Transporter_DEL}" />

                <Label text="{i18n>ewayBill}" />
                <Input id="inpEwayBill" value="{YY1_EwayBillNo_DEL}" />
            </form:content>
        </form:SimpleForm>
        <Toolbar id="challanToolbar">
            <ToolbarSpacer />
            <Button id="btnPrintChallan" text="{i18n>printChallan}" icon="sap-icon://print" type="Emphasized" press=".onPrintDeliveryChallan" />
        </Toolbar>
    </Panel>
</core:FragmentDefinition>
