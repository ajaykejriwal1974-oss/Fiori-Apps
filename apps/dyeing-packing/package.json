{
  "name": "kejriwal-dyeing-packing",
  "version": "1.0.0",
  "private": true,
  "description": "Custom Fiori app for textile dyeing packing (cone/carton/pallet structure, net/gross weights). Replaces ZPACK01D/02D/03D and ZREPACKD.",
  "keywords": [
    "ui5",
    "freestyle",
    "sap-fiori",
    "handling-unit",
    "packing",
    "s4hana-onpremise"
  ],
  "scripts": {
    "start": "ui5 serve --open \"index.html\"",
    "build": "ui5 build --clean-dest",
    "deploy": "npm run build && fiori deploy"
  },
  "devDependencies": {
    "@sap/ux-ui5-tooling": "1",
    "@ui5/cli": "^3"
  },
  "ui5": {
    "dependencies": [
      "@sap/ux-ui5-tooling"
    ]
  }
}
