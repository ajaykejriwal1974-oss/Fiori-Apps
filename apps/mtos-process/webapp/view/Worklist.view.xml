<mvc:View
    controllerName="kejriwal.pp.mtosprocess.controller.Worklist"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    displayBlock="true">
    <Page id="page" title="{i18n>appTitle}">
        <content>
            <Table
                id="table"
                items="{/MtosStock}"
                mode="MultiSelect"
                growing="true"
                growingThreshold="50">
                <headerToolbar>
                    <OverflowToolbar>
                        <Title text="{i18n>worklistTitle}"/>
                        <ToolbarSpacer/>
                        <Button text="{i18n>actconvertToMts}" press=".onConvertToMts" type="Emphasized"/>
                        <Button text="{i18n>actcreatePhysInvDoc}" press=".onCreatePhysInvDoc" type="Emphasized"/>
                    </OverflowToolbar>
                </headerToolbar>
                <columns>
                        <Column><Text text="{i18n>colMaterial}"/></Column>
                        <Column><Text text="{i18n>colPlant}"/></Column>
                        <Column><Text text="{i18n>colSalesOrder}"/></Column>
                        <Column><Text text="{i18n>colSalesOrderItem}"/></Column>
                        <Column><Text text="{i18n>colQuantity}"/></Column>
                        <Column><Text text="{i18n>colBaseUnit}"/></Column>
                </columns>
                <items>
                    <ColumnListItem>
                        <cells>
                            <Text text="{Material}"/>
                            <Text text="{Plant}"/>
                            <Text text="{SalesOrder}"/>
                            <Text text="{SalesOrderItem}"/>
                            <Text text="{Quantity}"/>
                            <Text text="{BaseUnit}"/>
                        </cells>
                    </ColumnListItem>
                </items>
            </Table>
        </content>
    </Page>
</mvc:View>
