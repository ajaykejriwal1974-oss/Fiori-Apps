{
  "_version": "1.65.0",
  "sap.app": {
    "id": "kejriwal.pm.maintenance",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "applicationVersion": {
      "version": "1.0.0"
    },
    "dataSources": {
      "mainService": {
        "uri": "/sap/opu/odata4/sap/zui_maintenance_o4/srvd/sap/zui_maintenance/0001/",
        "type": "OData",
        "settings": {
          "odataVersion": "4.0"
        }
      }
    },
    "crossNavigation": {
      "inbounds": {
        "Maintenance-manageKejriwal": {
          "semanticObject": "Maintenance",
          "action": "manageKejriwal",
          "icon": "sap-icon://maintenance",
          "title": "{{flpTitle}}",
          "subTitle": "{{flpSubtitle}}",
          "signature": {
            "parameters": {},
            "additionalParameters": "allowed"
          }
        }
      },
      "outbounds": {
        "toReportMalfunction": {
          "semanticObject": "MaintenanceProcessing",
          "action": "reportMalfunction"
        },
        "toMaintenanceOrder": {
          "semanticObject": "MaintenanceOrder",
          "action": "manage"
        },
        "toMaintenancePlan": {
          "semanticObject": "MaintenancePlan",
          "action": "manage"
        },
        "toTechnicalObject": {
          "semanticObject": "TechnicalObject",
          "action": "manage"
        },
        "toManageStock": {
          "semanticObject": "Material",
          "action": "manageStock"
        }
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "rootView": {
      "viewName": "kejriwal.pm.maintenance.view.Worklist",
      "type": "XML",
      "id": "worklist"
    },
    "dependencies": {
      "minUI5Version": "1.120.0",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {},
        "sap.ui.layout": {},
        "sap.f": {}
      }
    },
    "handleValidation": true,
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "kejriwal.pm.maintenance.i18n.i18n"
        }
      },
      "pm": {
        "type": "sap.ui.model.json.JSONModel",
        "uri": "model/data.json",
        "preload": true
      }
    },
    "contentDensities": {
      "compact": true,
      "cozy": true
    }
  }
}
