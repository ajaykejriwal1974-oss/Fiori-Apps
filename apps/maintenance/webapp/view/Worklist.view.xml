<mvc:View
    controllerName="kejriwal.pm.maintenance.controller.Worklist"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    displayBlock="true">
    <Page id="page" title="{i18n>appTitle}" class="sapUiContentPadding">
        <subHeader>
            <OverflowToolbar>
                <SegmentedButton selectedKey="{view>/section}" selectionChange=".onSection" width="100%">
                    <items>
                        <SegmentedButtonItem key="schedule" text="{i18n>tabSchedule}"/>
                        <SegmentedButtonItem key="breakdown" text="{i18n>tabBreakdown}"/>
                        <SegmentedButtonItem key="machines" text="{i18n>tabMachines}"/>
                        <SegmentedButtonItem key="parts" text="{i18n>tabSpareParts}"/>
                        <SegmentedButtonItem key="budget" text="{i18n>tabBudget}"/>
                    </items>
                </SegmentedButton>
            </OverflowToolbar>
        </subHeader>
        <content>
            <!-- ============ Schedule (preventive) maintenance ============ -->
            <Table id="planTable" visible="{= ${view>/section} === 'schedule'}"
                items="{pm>/maintenancePlans}" mode="MultiSelect">
                <headerToolbar>
                    <OverflowToolbar>
                        <Title text="{parts: [{path: 'i18n>schedTitle'}, {path: 'pm>/maintenancePlans'}], formatter: '.formatter.countTitle'}"/>
                        <ToolbarSpacer/>
                        <SearchField id="planSearch" width="14rem" search=".onSearchPlans" liveChange=".onSearchPlans"/>
                        <Button text="{i18n>btnCreatePlan}" icon="sap-icon://add" type="Emphasized" press=".onCreatePlan"/>
                        <Button text="{i18n>btnEditPlan}" icon="sap-icon://edit" press=".onEditPlan"/>
                        <Button text="{i18n>btnScheduleNow}" icon="sap-icon://date-time" press=".onScheduleNow"/>
                        <Button text="{i18n>btnSetActive}" press=".onSetActive"/>
                        <Button text="{i18n>btnSetInactive}" press=".onSetInactive"/>
                        <Button text="{i18n>btnDelete}" icon="sap-icon://delete" press=".onDeletePlans"/>
                        <Button text="{i18n>btnStdPlan}" icon="sap-icon://action" press=".onStdMaintenancePlan">
                            <layoutData><OverflowToolbarLayoutData priority="Low"/></layoutData>
                        </Button>
                    </OverflowToolbar>
                </headerToolbar>
                <columns>
                    <Column><Text text="{i18n>colPlanId}"/></Column>
                    <Column><Text text="{i18n>colEquipment}"/></Column>
                    <Column minScreenWidth="Tablet" demandPopin="true"><Text text="{i18n>colMaintType}"/></Column>
                    <Column minScreenWidth="Tablet" demandPopin="true"><Text text="{i18n>colCycle}"/></Column>
                    <Column minScreenWidth="Desktop" demandPopin="true"><Text text="{i18n>colWorkCenter}"/></Column>
                    <Column minScreenWidth="Desktop" demandPopin="true"><Text text="{i18n>colCostCenter}"/></Column>
                    <Column hAlign="End" minScreenWidth="Desktop" demandPopin="true"><Text text="{i18n>colEstCost}"/></Column>
                    <Column><Text text="{i18n>colNextDue}"/></Column>
                    <Column><Text text="{i18n>colPriority}"/></Column>
                    <Column><Text text="{i18n>colPlanStatus}"/></Column>
                </columns>
                <items>
                    <ColumnListItem>
                        <cells>
                            <ObjectIdentifier title="{pm>PlanId}" text="{pm>EquipmentDesc}"/>
                            <Text text="{pm>Equipment}"/>
                            <Text text="{pm>MaintenanceType}"/>
                            <Text text="{parts: [{path: 'pm>CycleLength'}, {path: 'pm>CycleUnit'}], formatter: '.formatter.cycleText'}"/>
                            <Text text="{pm>WorkCenter}"/>
                            <Text text="{pm>CostCenter}"/>
                            <Text text="{parts: [{path: 'pm>EstimatedCost'}, {path: 'pm>Currency'}], formatter: '.formatter.amountText'}"/>
                            <Text text="{pm>NextDueDate}"/>
                            <ObjectStatus text="{pm>Priority}" state="{path: 'pm>Priority', formatter: '.formatter.priorityState'}"/>
                            <ObjectStatus text="{pm>PlanStatus}" state="{path: 'pm>PlanStatus', formatter: '.formatter.planStatusState'}"/>
                        </cells>
                    </ColumnListItem>
                </items>
            </Table>

            <!-- ============ Breakdown (corrective) maintenance ============ -->
            <Table id="breakdownTable" visible="{= ${view>/section} === 'breakdown'}"
                items="{pm>/breakdownReports}" mode="MultiSelect">
                <headerToolbar>
                    <OverflowToolbar>
                        <Title text="{parts: [{path: 'i18n>bdTitle'}, {path: 'pm>/breakdownReports'}], formatter: '.formatter.countTitle'}"/>
                        <ToolbarSpacer/>
                        <SearchField id="bdSearch" width="14rem" search=".onSearchBreakdowns" liveChange=".onSearchBreakdowns"/>
                        <Button text="{i18n>btnReportBreakdown}" icon="sap-icon://add" type="Emphasized" press=".onReportBreakdown"/>
                        <Button text="{i18n>btnAcknowledge}" icon="sap-icon://accept" press=".onAcknowledge"/>
                        <Button text="{i18n>btnComplete}" icon="sap-icon://complete" press=".onComplete"/>
                        <Button text="{i18n>btnDelete}" icon="sap-icon://delete" press=".onDeleteBreakdowns"/>
                        <Button text="{i18n>btnStdReport}" icon="sap-icon://action" press=".onStdReportMalfunction">
                            <layoutData><OverflowToolbarLayoutData priority="Low"/></layoutData>
                        </Button>
                    </OverflowToolbar>
                </headerToolbar>
                <columns>
                    <Column><Text text="{i18n>colNotifId}"/></Column>
                    <Column><Text text="{i18n>colEquipment}"/></Column>
                    <Column minScreenWidth="Tablet" demandPopin="true"><Text text="{i18n>colMalfunction}"/></Column>
                    <Column minScreenWidth="Desktop" demandPopin="true"><Text text="{i18n>colFailureMode}"/></Column>
                    <Column minScreenWidth="Tablet" demandPopin="true"><Text text="{i18n>colBreakdownStart}"/></Column>
                    <Column minScreenWidth="Desktop" demandPopin="true"><Text text="{i18n>colDowntime}"/></Column>
                    <Column hAlign="End" minScreenWidth="Desktop" demandPopin="true"><Text text="{i18n>colTotalCost}"/></Column>
                    <Column minScreenWidth="Desktop" demandPopin="true"><Text text="{i18n>colWorkOrder}"/></Column>
                    <Column><Text text="{i18n>colPriority}"/></Column>
                    <Column><Text text="{i18n>colBdStatus}"/></Column>
                </columns>
                <items>
                    <ColumnListItem>
                        <cells>
                            <ObjectIdentifier title="{pm>NotificationId}" text="{pm>Description}"/>
                            <Text text="{pm>Equipment}"/>
                            <Text text="{pm>MalfunctionType}"/>
                            <Text text="{pm>FailureMode}"/>
                            <Text text="{pm>BreakdownStart}"/>
                            <Text text="{parts: [{path: 'pm>DowntimeHours'}, {path: 'pm>DowntimeUnit'}], formatter: '.formatter.downtimeText'}"/>
                            <Text text="{parts: [{path: 'pm>TotalCost'}, {path: 'pm>Currency'}], formatter: '.formatter.amountText'}"/>
                            <Text text="{pm>WorkOrder}"/>
                            <ObjectStatus text="{pm>Priority}" state="{path: 'pm>Priority', formatter: '.formatter.priorityState'}"/>
                            <ObjectStatus text="{pm>BreakdownStatus}" state="{path: 'pm>BreakdownStatus', formatter: '.formatter.breakdownStatusState'}"/>
                        </cells>
                    </ColumnListItem>
                </items>
            </Table>

            <!-- ============ Machines / Work Centers ============ -->
            <Table id="machineTable" visible="{= ${view>/section} === 'machines'}"
                items="{pm>/machines}" mode="MultiSelect">
                <headerToolbar>
                    <OverflowToolbar>
                        <Title text="{parts: [{path: 'i18n>machineTitle'}, {path: 'pm>/machines'}], formatter: '.formatter.countTitle'}"/>
                        <ToolbarSpacer/>
                        <SearchField id="machineSearch" width="14rem" search=".onSearchMachines" liveChange=".onSearchMachines"/>
                        <Button text="{i18n>btnCreateMachine}" icon="sap-icon://add" type="Emphasized" press=".onCreateMachine"/>
                        <Button text="{i18n>btnEditMachine}" icon="sap-icon://edit" press=".onEditMachine"/>
                        <Button text="{i18n>btnDelete}" icon="sap-icon://delete" press=".onDeleteMachines"/>
                        <Button text="{i18n>btnStdTech}" icon="sap-icon://action" press=".onStdTechnicalObject">
                            <layoutData><OverflowToolbarLayoutData priority="Low"/></layoutData>
                        </Button>
                    </OverflowToolbar>
                </headerToolbar>
                <columns>
                    <Column><Text text="{i18n>colMachineId}"/></Column>
                    <Column minScreenWidth="Tablet" demandPopin="true"><Text text="{i18n>colPlant}"/></Column>
                    <Column minScreenWidth="Tablet" demandPopin="true"><Text text="{i18n>colCategory}"/></Column>
                    <Column hAlign="End" minScreenWidth="Desktop" demandPopin="true"><Text text="{i18n>colCapacity}"/></Column>
                    <Column minScreenWidth="Desktop" demandPopin="true"><Text text="{i18n>colCostCenter}"/></Column>
                    <Column hAlign="End" minScreenWidth="Desktop" demandPopin="true"><Text text="{i18n>colHourlyRate}"/></Column>
                    <Column><Text text="{i18n>colCriticality}"/></Column>
                    <Column><Text text="{i18n>colMachineStatus}"/></Column>
                </columns>
                <items>
                    <ColumnListItem>
                        <cells>
                            <ObjectIdentifier title="{pm>MachineId}" text="{pm>Description}"/>
                            <Text text="{pm>Plant}"/>
                            <Text text="{pm>Category}"/>
                            <Text text="{pm>CapacityPerDay}"/>
                            <Text text="{pm>CostCenter}"/>
                            <Text text="{parts: [{path: 'pm>HourlyRate'}, {path: 'pm>Currency'}], formatter: '.formatter.amountText'}"/>
                            <ObjectStatus text="{pm>Criticality}" state="{path: 'pm>Criticality', formatter: '.formatter.criticalityState'}"/>
                            <ObjectStatus text="{pm>MachineStatus}" state="{path: 'pm>MachineStatus', formatter: '.formatter.machineStatusState'}"/>
                        </cells>
                    </ColumnListItem>
                </items>
            </Table>

            <!-- ============ Spare Parts / Inventory ============ -->
            <Table id="partTable" visible="{= ${view>/section} === 'parts'}"
                items="{pm>/spareParts}" mode="MultiSelect">
                <headerToolbar>
                    <OverflowToolbar>
                        <Title text="{parts: [{path: 'i18n>spareTitle'}, {path: 'pm>/spareParts'}], formatter: '.formatter.countTitle'}"/>
                        <ToolbarSpacer/>
                        <SearchField id="partSearch" width="14rem" search=".onSearchParts" liveChange=".onSearchParts"/>
                        <Button text="{i18n>btnCreatePart}" icon="sap-icon://add" type="Emphasized" press=".onCreatePart"/>
                        <Button text="{i18n>btnEditPart}" icon="sap-icon://edit" press=".onEditPart"/>
                        <Button text="{i18n>btnIssueStock}" icon="sap-icon://journey-arrive" press=".onIssueStock"/>
                        <Button text="{i18n>btnReceiveStock}" icon="sap-icon://journey-depart" press=".onReceiveStock"/>
                        <Button text="{i18n>btnDelete}" icon="sap-icon://delete" press=".onDeleteParts"/>
                        <Button text="{i18n>btnStdStock}" icon="sap-icon://action" press=".onStdManageStock">
                            <layoutData><OverflowToolbarLayoutData priority="Low"/></layoutData>
                        </Button>
                    </OverflowToolbar>
                </headerToolbar>
                <columns>
                    <Column><Text text="{i18n>colPartNumber}"/></Column>
                    <Column minScreenWidth="Tablet" demandPopin="true"><Text text="{i18n>colMachine}"/></Column>
                    <Column minScreenWidth="Desktop" demandPopin="true"><Text text="{i18n>colStorageBin}"/></Column>
                    <Column hAlign="End"><Text text="{i18n>colStockQty}"/></Column>
                    <Column hAlign="End" minScreenWidth="Tablet" demandPopin="true"><Text text="{i18n>colReorderPoint}"/></Column>
                    <Column hAlign="End" minScreenWidth="Desktop" demandPopin="true"><Text text="{i18n>colUnitPrice}"/></Column>
                    <Column hAlign="End" minScreenWidth="Desktop" demandPopin="true"><Text text="{i18n>colStockValue}"/></Column>
                    <Column minScreenWidth="Desktop" demandPopin="true"><Text text="{i18n>colVendor}"/></Column>
                    <Column><Text text="{i18n>colAvailability}"/></Column>
                </columns>
                <items>
                    <ColumnListItem>
                        <cells>
                            <ObjectIdentifier title="{pm>PartNumber}" text="{pm>Description}"/>
                            <Text text="{pm>Machine}"/>
                            <Text text="{pm>StorageBin}"/>
                            <ObjectNumber number="{pm>StockQty}" unit="{pm>BaseUnit}"/>
                            <Text text="{pm>ReorderPoint}"/>
                            <Text text="{parts: [{path: 'pm>UnitPrice'}, {path: 'pm>Currency'}], formatter: '.formatter.amountText'}"/>
                            <Text text="{parts: [{path: 'pm>StockQty'}, {path: 'pm>UnitPrice'}, {path: 'pm>Currency'}], formatter: '.formatter.stockValueText'}"/>
                            <Text text="{pm>Vendor}"/>
                            <ObjectStatus text="{pm>Availability}" state="{path: 'pm>Availability', formatter: '.formatter.availabilityState'}"/>
                        </cells>
                    </ColumnListItem>
                </items>
            </Table>

            <!-- ============ Maintenance Budget ============ -->
            <Table id="budgetTable" visible="{= ${view>/section} === 'budget'}"
                items="{pm>/budgets}" mode="MultiSelect">
                <headerToolbar>
                    <OverflowToolbar>
                        <Title text="{parts: [{path: 'i18n>budgetTitle'}, {path: 'pm>/budgets'}], formatter: '.formatter.countTitle'}"/>
                        <ToolbarSpacer/>
                        <SearchField id="budgetSearch" width="14rem" search=".onSearchBudgets" liveChange=".onSearchBudgets"/>
                        <Button text="{i18n>btnCreateBudget}" icon="sap-icon://add" type="Emphasized" press=".onCreateBudget"/>
                        <Button text="{i18n>btnEditBudget}" icon="sap-icon://edit" press=".onEditBudget"/>
                        <Button text="{i18n>btnPostActual}" icon="sap-icon://money-bills" press=".onPostActual"/>
                        <Button text="{i18n>btnDelete}" icon="sap-icon://delete" press=".onDeleteBudgets"/>
                    </OverflowToolbar>
                </headerToolbar>
                <columns>
                    <Column><Text text="{i18n>colBudgetId}"/></Column>
                    <Column minScreenWidth="Tablet" demandPopin="true"><Text text="{i18n>colCostCenter}"/></Column>
                    <Column minScreenWidth="Tablet" demandPopin="true"><Text text="{i18n>colFiscalYear}"/></Column>
                    <Column minScreenWidth="Desktop" demandPopin="true"><Text text="{i18n>colCategory}"/></Column>
                    <Column hAlign="End"><Text text="{i18n>colPlanned}"/></Column>
                    <Column hAlign="End"><Text text="{i18n>colActual}"/></Column>
                    <Column hAlign="End" minScreenWidth="Desktop" demandPopin="true"><Text text="{i18n>colVariance}"/></Column>
                    <Column><Text text="{i18n>colUtilization}"/></Column>
                </columns>
                <items>
                    <ColumnListItem>
                        <cells>
                            <ObjectIdentifier title="{pm>BudgetId}" text="{pm>CostCenter}"/>
                            <Text text="{pm>CostCenter}"/>
                            <Text text="{pm>FiscalYear}"/>
                            <Text text="{pm>Category}"/>
                            <Text text="{parts: [{path: 'pm>PlannedAmount'}, {path: 'pm>Currency'}], formatter: '.formatter.amountText'}"/>
                            <Text text="{parts: [{path: 'pm>ActualAmount'}, {path: 'pm>Currency'}], formatter: '.formatter.amountText'}"/>
                            <Text text="{parts: [{path: 'pm>Variance'}, {path: 'pm>Currency'}], formatter: '.formatter.amountText'}"/>
                            <ObjectStatus text="{path: 'pm>UtilizationPct', formatter: '.formatter.utilizationText'}" state="{path: 'pm>UtilizationPct', formatter: '.formatter.utilizationState'}"/>
                        </cells>
                    </ColumnListItem>
                </items>
            </Table>
        </content>
    </Page>
</mvc:View>
